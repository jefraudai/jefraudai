        "type": "function",
        "z": "19324f111076af83",
        "name": "api_conso_electrique_agregats_30min_points_soutirage_all",
        "func": "// Initialisation\n\nconst NomFile = node.name + '.json';\nconst filePath = \"/data/\" + NomFile;   // <-- IMPORTANT\nflow.set('allResults', []);\nflow.set('pageCount', 0);\nflow.set('NomFile', NomFile );\n\nconst firstUrl = 'https://opendata.enedis.fr/data-fair/api/v1/datasets/conso-sup36-region/lines?page=1&format=json&size=5000';\nflow.set('nextUrl', firstUrl);\n\nmsg.payload = filePath ;\nmsg.url = firstUrl;\nnode.warn('Fichier à supprimer: ' + filePath);\nnode.warn('Démarrage - URL: ' + firstUrl);\nreturn msg;",
        "outputs": 1,
