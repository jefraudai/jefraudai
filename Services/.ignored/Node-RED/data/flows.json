        "name": "Build MinIO Command",
        "func": "const filePath = msg.filename;\n// filePath = '/data/nom_fichier.json'\n\nconst fileName = filePath.split('/').pop();\n// fileName = 'nom_fichier.json'\n\nconst minioDest = 'local/datalake/' + fileName;\n\nmsg.payload = `mc alias set local http://minio:9000 admin password && mc cp ${filePath} ${minioDest}`;\n\nnode.warn('Commande MinIO: ' + msg.payload);\nreturn msg;",
