    {
        "id": "37779faa15868db2",
        "type": "function",
        "z": "19324f111076af83",
        "name": "Process & Check Next",
        "func": "const data = msg.payload;\nconst max = 2;\n\n// Vérification erreur HTTP\nif (msg.statusCode !== 200) {\n    node.error('Erreur HTTP: ' + msg.statusCode);\n    return null;\n}\n\nconst newResults = data.results;\n\nconst valuLigne =  data.length + flow.get('valuLigne') || 0 \nflow.set('valuLigne', valuLigne);\n\n\n// Compteur de pages\nconst pageCount = (flow.get('pageCount') || 0) + 1;\nflow.set('pageCount', pageCount);\n\nnode.warn(`Page récupérée : ${pageCount} pour ${valuLigne} lignes au total`);\n\n// Déterminer si premier passage\nconst isFirst = pageCount === 1;\n\n// Déterminer si dernier passage\nconst isLast = !data.next ;//|| pageCount >= max;\n\n// Construction du chunk JSON\nlet chunk = \"\";\n\n// ➜ début du tableau\nif (isFirst) {\n    chunk += \"[\";\n}\n\n// ➜ contenu (sans [] autour)\nchunk += newResults.map(obj => JSON.stringify(obj)).join(\",\\n\");\n\n// ➜ fin du tableau\nif (isLast) {\n    chunk += \"]\";\n} else {\n    chunk += \",\\n\";\n}\n\n// Conversion en buffer\nconst fileName = flow.get('NomFile');\nmsg.payload = Buffer.from(chunk);\nmsg.filename = '/data/' + fileName;\n\nnode.warn(`Page ${pageCount} - ${newResults.length} résultats`);\n\n// Pagination\nif (!isLast) {\n    msg.url = data.next;\n    return [msg, null];\n} else {\n    node.warn('Pagination terminée');\n    return [null, msg];\n}",
